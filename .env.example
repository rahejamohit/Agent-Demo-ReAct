# Flight Price Aggregator API Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_TITLE=Flight Price Aggregator API
API_VERSION=1.0.0

# ============================================================================
# LLM Provider Configuration (REQUIRED)
# ============================================================================
# Select which LLM provider to use: google, openai, or anthropic
LLM_PROVIDER=google

# Optional: Override the default model for the selected provider
# LLM_MODEL=gemini-2-flash

# ============================================================================
# LLM API Keys (set the one matching LLM_PROVIDER)
# ============================================================================
# Google Gemini - Required if LLM_PROVIDER=google
# Get key from: https://ai.google.dev
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI GPT-4 - Required if LLM_PROVIDER=openai
# Get key from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude - Required if LLM_PROVIDER=anthropic
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# API Administration
# ============================================================================
ADMIN_KEY=dev-admin-key

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============================================================================
# External Flight Provider APIs (for future integration)
# ============================================================================
SKYSCANNER_API_KEY=your_key_here
KAYAK_API_KEY=your_key_here
GOOGLE_FLIGHTS_API_KEY=your_key_here
EXPEDIA_API_KEY=your_key_here
AMADEUS_API_KEY=your_key_here

# ============================================================================
# Database Configuration (for future use)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/flight_db

# ============================================================================
# Redis Cache Configuration (for future use)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
