# Flight Price Aggregator API Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_TITLE=Flight Price Aggregator API
API_VERSION=1.0.0

# Admin
ADMIN_KEY=dev-admin-key

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# External API Keys (for future integration)
SKYSCANNER_API_KEY=your_key_here
KAYAK_API_KEY=your_key_here
GOOGLE_FLIGHTS_API_KEY=your_key_here
EXPEDIA_API_KEY=your_key_here

# Database (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/flight_db

# Redis Cache (for future use)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=development
